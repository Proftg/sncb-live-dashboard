# SNCB Live Dashboard - Environment Variables
# Copy this file to .env and fill in the values

# GTFS Static Data URL
GTFS_URL=https://gtfs.irail.be/nmbs/gtfs/latest.zip

# GTFS Realtime URLs (optional, defaults are set in code)
GTFS_RT_TRIP_UPDATES_URL=https://gtfs.irail.be/nmbs/gtfs-rt/tripUpdates.pb
GTFS_RT_VEHICLE_POSITIONS_URL=https://gtfs.irail.be/nmbs/gtfs-rt/vehiclePositions.pb
GTFS_RT_ALERTS_URL=https://gtfs.irail.be/nmbs/gtfs-rt/alerts.pb

# API Key (if required by the GTFS-RT provider)
# API_KEY=your_api_key_here
